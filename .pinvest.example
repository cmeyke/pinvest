# pinvest configuration
# Copy this file to .pinvest and edit to match your portfolio.
# .pinvest is git-ignored so your holdings stay local.

# Number of shares you currently own per asset class (set to 0 if you hold none)
[holdings]
Equity = 0
Bonds = 0
Gold = 0

# Which ETF / ETC ticker to use for each asset class
# (change a ticker here only — holdings stay untouched)
[vehicles]
Equity = "SPYY"
Bonds = "XGLE"
Gold = "EWG2"
