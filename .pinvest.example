# pinvest configuration
# Copy this file to .pinvest and edit to match your portfolio.
# .pinvest is git-ignored so your holdings stay local.

# ══ Asset allocation strategy ══
[strategy]
band = 0.20                     # 20 % relative tolerance band

[strategy.targets]
Equity = 0.60                   # fractions must sum to 1.0
Bonds  = 0.25
Gold   = 0.15

# ══ Your current holdings ══
[holdings]
Equity = 0
Bonds  = 0
Gold   = 0

# ══ Vehicles (tickers) ══
# Change a ticker here only — holdings stay untouched.
# Each entry may be a plain string (uses the default primary exchange)
# or a table with an explicit primary_exchange override, e.g. for tickers
# whose main listing is on a non-default exchange:
#
#   [vehicles]
#   Equity = "SPYY"
#   Bonds  = "XGLE"
#   Gold   = { symbol = "EWG2", primary_exchange = "SWB" }
[vehicles]
Equity = "SPYY"
Bonds  = "XGLE"
Gold   = { symbol = "EWG2", primary_exchange = "SWB" }
